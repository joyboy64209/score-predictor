generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum MarketType {
  MATCH_RESULT
  DOUBLE_CHANCE
  BTTS
  OVER_UNDER
  TEAM_GOALS
  FIRST_TEAM_TO_SCORE
  CLEAN_SHEET
  DRAW_NO_BET
  WIN_TO_NIL
  EXACT_SCORE
  GOAL_RANGE
  HALF_WINNER
  COMBINATION
}

enum PredictionStatus {
  QUALIFIED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model League {
  id        String   @id @default(cuid())
  name      String
  country   String?
  externalId String?
  createdAt DateTime @default(now())
  seasons   Season[]
  fixtures  Fixture[]
}

model Season {
  id        String   @id @default(cuid())
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  fixtures  Fixture[]
  stats     TeamSeasonStat[]
  @@unique([leagueId, name])
}

model Team {
  id         String    @id @default(cuid())
  name       String
  shortName  String?
  externalId String?
  createdAt  DateTime  @default(now())
  homeFixtures Fixture[] @relation("homeTeam")
  awayFixtures Fixture[] @relation("awayTeam")
  stats         TeamSeasonStat[]
}

model Fixture {
  id         String   @id @default(cuid())
  leagueId   String
  league     League   @relation(fields: [leagueId], references: [id])
  seasonId   String
  season     Season   @relation(fields: [seasonId], references: [id])
  homeTeamId String
  homeTeam   Team     @relation("homeTeam", fields: [homeTeamId], references: [id])
  awayTeamId String
  awayTeam   Team     @relation("awayTeam", fields: [awayTeamId], references: [id])
  matchday   Int?
  kickoff    DateTime
  status     String   @default("SCHEDULED")
  homeScore  Int?
  awayScore  Int?
  externalId String?
  createdAt  DateTime @default(now())
  predictions Prediction[]
  @@index([seasonId, matchday])
}

model TeamSeasonStat {
  id           String @id @default(cuid())
  teamId       String
  team         Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  seasonId     String
  season       Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  isHome       Boolean @default(false)
  played       Int    @default(0)
  wins         Int    @default(0)
  draws        Int    @default(0)
  losses       Int    @default(0)
  goalsFor     Int    @default(0)
  goalsAgainst Int    @default(0)
  @@unique([teamId, seasonId, isHome])
}

model Prediction {
  id            String           @id @default(cuid())
  fixtureId     String
  fixture       Fixture          @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  market        MarketType
  selection     String
  probability   Float
  confidence    Float
  expectedValue Float?
  status        PredictionStatus @default(QUALIFIED)
  reasons       Json?
  modelVersion  String?
  createdAt     DateTime         @default(now())
  @@index([fixtureId, status])
}

model ModelVersion {
  id            String   @id @default(cuid())
  name          String
  algorithm     String
  metrics       Json?
  trainedAt     DateTime @default(now())
  isActive      Boolean  @default(false)
}

model Config {
  id    String @id @default("singleton")
  thresholds Json
  updatedAt DateTime @updatedAt
}

model Player {
  id         String @id @default(cuid())
  name       String
  teamId     String?
  externalId String?
  position   String?
  createdAt  DateTime @default(now())
}

model Venue {
  id         String @id @default(cuid())
  name       String
  city       String?
  externalId String?
}

model MatchStatistic {
  id                  String   @id @default(cuid())
  fixtureId           String
  homeShots           Int?
  awayShots           Int?
  homeShotsOnTarget   Int?
  awayShotsOnTarget   Int?
  homePossession      Float?
  awayPossession      Float?
  homePassAccuracy    Float?
  awayPassAccuracy    Float?
  homeCorners         Int?
  awayCorners         Int?
  homeYellow          Int?
  awayYellow          Int?
  homeRed             Int?
  awayRed             Int?
  homeXg              Float?
  awayXg              Float?
  homeXga             Float?
  awayXga             Float?
}

model PlayerStatistic {
  id        String  @id @default(cuid())
  fixtureId String
  playerName String
  teamName  String
  minutes   Int?
  goals     Int     @default(0)
  assists   Int     @default(0)
  rating    Float?
}

model Standing {
  id         String @id @default(cuid())
  competition String
  season     String
  teamName   String
  position   Int
  played     Int    @default(0)
  wins       Int    @default(0)
  draws      Int    @default(0)
  losses     Int    @default(0)
  goalsFor   Int    @default(0)
  goalsAgainst Int  @default(0)
  points     Int    @default(0)
}

model AdvancedMetric {
  id    String  @id @default(cuid())
  teamName String
  season  String
  xg     Float?
  xga    Float?
  xpts   Float?
  npxg   Float?
  npxga  Float?
  ppda   Float?
  deep   Float?
  sca    Float?
}

model Injury {
  id        String @id @default(cuid())
  teamName  String
  playerName String
  reason    String?
  type      String?
  until     String?
}

model Suspension {
  id        String @id @default(cuid())
  teamName  String
  playerName String
  reason    String?
  until     String?
}

model Lineup {
  id        String @id @default(cuid())
  fixtureId String
  teamName  String
  formation String?
  starting  Json?
  substitutes Json?
}

model EventData {
  id         String  @id @default(cuid())
  fixtureId  String
  eventType  String
  teamName   String
  playerName String?
  minute     Int?
  x          Float?
  y          Float?
  endX       Float?
  endY       Float?
  extra      Json?
}

model EloRating {
  id       String @id @default(cuid())
  teamName String
  rating   Float
  rank     Int?
  date     String?
  country  String?
}

model Odds {
  id        String  @id @default(cuid())
  fixtureId String
  bookmaker String?
  home      Float?
  draw      Float?
  away      Float?
}

model FeatureRow {
  id             String   @id @default(cuid())
  fixtureId      String
  features       Json
  label          Int
  datasetVersion String
  createdAt      DateTime @default(now())
}
